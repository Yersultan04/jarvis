# ============================================================
# Sana на GCP VM — конфиг. setup.sh подставит __SANA_HOME__ автоматически.
# Скопируется в bot/.env. Заполни секреты (этот файл-шаблон без секретов).
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Твой Telegram ID (доступ залочен на него)
JARVIS_ALLOWED_USERS=501125622

# --- Мозг: claude -p на подписке (headless) ---
# Токен из `claude setup-token`. НЕ задавай ANTHROPIC_API_KEY (перебьёт подписку).
CLAUDE_CODE_OAUTH_TOKEN=
# claude в PATH (npm global) — пусто = авто-детект
CLAUDE_BIN=
# 1GB VM медленнее — даём claude -p больше времени
CLAUDE_TIMEOUT=240
JARVIS_CHELSEA_TIMEOUT=300
JARVIS_BUILDER_TIMEOUT=900

# --- Рабочее пространство (= клон памяти sana-memory) ---
JARVIS_WORKSPACE=__SANA_HOME__
# /task (билдер) запускать прямо в код-репо, иначе claude гейтит git вне рабочего корня
JARVIS_BUILDER_CWD=__CODE_DIR__

# --- G7: rag-cms на 1GB не поднимаем → быстрый путь выключен, всё через claude -p ---
JARVIS_RAG_ENABLED=0
# rag-cms креды не нужны при RAG_ENABLED=0 (оставлены для совместимости)
JARVIS_API_BASE=http://127.0.0.1:8000

# --- Голос: Groq Whisper (STT). Ключи через запятую (ротация) ---
GROQ_API_KEYS=
FFMPEG_BIN=ffmpeg

# --- Проактивность ---
JARVIS_BRIEF_TIME=08:30
JARVIS_BRIEF_ENABLED=1
JARVIS_WATCH_MIN=30
