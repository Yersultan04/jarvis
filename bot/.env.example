# Jarvis Telegram-бот — конфиг
# Скопируй в .env и заполни TELEGRAM_BOT_TOKEN (+ JARVIS_ALLOWED_USERS для приватности)

# Токен от @BotFather (/newbot → скопировать строку вида 123456:ABC-...)
TELEGRAM_BOT_TOKEN=

# Локальный rag-cms API
JARVIS_API_BASE=http://127.0.0.1:8000
JARVIS_RAG_ID=
JARVIS_EMAIL=
JARVIS_PASSWORD=

# Telegram user_id, которым разрешён доступ (через запятую).
# Пусто = отвечать всем (НЕ рекомендуется). Свой ID узнаешь, написав боту /start.
JARVIS_ALLOWED_USERS=
